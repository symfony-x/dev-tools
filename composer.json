{
  "name": "symfony-x/dev-tools",
  "description": "Shared QA, static analysis, and architecture tooling for Symfony-X",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.66",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^11.4",
    "symfony/filesystem": "8.0.*",
    "symfony/finder": "8.0.*",
    "symfony/process": "8.0.*"
  },
  "autoload": {
    "psr-4": {
      "SymfonyX\\DevTools\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SymfonyX\\DevTools\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/symfony-x-arch-validate",
    "bin/symfony-x-package-validate"
  ],
  "config": {
    "sort-packages": true
  }
}